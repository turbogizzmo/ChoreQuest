# Copy this file to .env and fill in your values
# cp .env.example .env

# Required — must be at least 16 characters, use something random
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Your timezone (default: UTC)
# Find yours: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Chicago

# Optional — set to true if running behind HTTPS (enables Secure cookies + HSTS)
# COOKIE_SECURE=true

# Optional — allow cross-origin requests (comma-separated origins)
# CORS_ORIGINS=https://chorequest.yourdomain.com

# Optional — enable self-registration (default: false, admin creates all accounts)
# REGISTRATION_ENABLED=true

# Optional — GitHub repo for in-app update checks (default: turbogizzmo/ChoreQuest)
# GITHUB_REPO=yourusername/ChoreQuest

# Optional — expose internal /debug endpoints (dev only, default: false)
# When false, /api/chores/{id}/debug returns 404 even to authenticated parents
# ENABLE_DEBUG_ENDPOINTS=true
